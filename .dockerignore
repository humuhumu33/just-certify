# Keep the build context small so the platform builder doesn't
# re-upload hundreds of MB of build artifacts on every deploy.

# Rust build output (regenerated inside the image).
**/target/
**/*.rs.bk

# Per-crate lockfiles (workspace Cargo.lock is authoritative).
**/Cargo.lock
!/Cargo.lock

# Git + editor state.
.git/
.gitignore
.vscode/
.idea/
.DS_Store
.claude/

# Python bycatch (if any test scripts land in-tree).
**/__pycache__/
**/*.pyc

# Markdown docs aren't needed inside the image — GitHub renders them.
# The DID document is JSON, so it's not matched by this pattern and
# travels with the build context correctly.
**/*.md
