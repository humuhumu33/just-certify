# Rust build artifacts
/target/
**/target/
**/*.rs.bk

# Per-crate Cargo.lock — only the workspace Cargo.lock matters.
**/Cargo.lock
!/Cargo.lock

# Editor / IDE state
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~
.claude/

# Python bycatch (if test scripts are run in-tree)
__pycache__/
*.pyc
*.pyo

# Runtime / secrets
.env
.env.*
*.pem
*.key
*_rsa
*_ed25519
